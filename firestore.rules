rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===========================
    // HELPER FUNCTIONS
    // ===========================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidOutletInitPayload() {
      return request.resource.data.keys().hasOnly([
        'outletNumber',
        'status',
        'applianceName',
        'voltage',
        'current',
        'power',
        'energy',
        'totalEnergy',
        'lastUpdated',
        'autoDetectedAppliance'
      ]);
    }

    // Device mapping docs used by Cloud Functions to resolve ESP32 ownership.
    match /devices/{deviceId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ===========================
    // USERS COLLECTION
    // ===========================
    
    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if isOwner(userId);
      
      // ===========================
      // OUTLETS SUBCOLLECTION
      // ===========================
      match /outlets/{outletId} {
        // Users can read outlets, initialize outlet docs, and rename appliances.
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidOutletInitPayload();
        allow update: if isOwner(userId)
                      && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['applianceName', 'lastUpdated', 'outletNumber']);
        allow delete: if false;
      }
      
      // ===========================
      // HISTORY_LOGS SUBCOLLECTION
      // ===========================
      match /history_logs/{logId} {
        // 🔒 LOCKED: Users can only READ
        allow read: if isOwner(userId);
        allow write: if false;  // Only Cloud Functions can write
      }
      
      // ===========================
      // HISTORY_DAILY SUBCOLLECTION
      // ===========================
      match /history_daily/{date} {
        // 🔒 LOCKED: Users can only READ
        allow read: if isOwner(userId);
        allow write: if false;  // Only Cloud Functions can write
      }
      
      // ===========================
      // SCHEDULES SUBCOLLECTION
      // ===========================
      match /schedules/{scheduleId} {
        // ✅ OPEN: Users can fully manage their schedules
        allow read, write: if isOwner(userId);
      }
      
      // ===========================
      // BUDGET SUBCOLLECTION
      // ===========================
      match /budget/{month} {
        // Users can manage their own monthly budget documents.
        allow read, write: if isOwner(userId);
      }
      
      // ===========================
      // NOTIFICATIONS SUBCOLLECTION
      // ===========================
      match /notifications/{notificationId} {
        // Users can read notifications; create is allowed for in-app manual/testing notifications.
        allow read: if isOwner(userId);
        
        allow create: if isOwner(userId);
        
        // Users can ONLY update the 'read' field (mark as read)
        allow update: if isOwner(userId) && 
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
        
        // Users can DELETE their own notifications
        allow delete: if isOwner(userId);
      }

      // ===========================
      // DEVICE_COMMANDS SUBCOLLECTION
      // ===========================
      match /device_commands/{commandId} {
        // Users can inspect command lifecycle; writes remain server-side only.
        allow read: if isOwner(userId);
        allow write: if false;
      }
      
      // ===========================
      // POWER_SAFETY SUBCOLLECTION
      // ===========================
      match /power_safety/{document=**} {
        // ✅ OPEN: Users can read and write power safety settings
        allow read, write: if isOwner(userId);
      }
      
      // ===========================
      // REFERENCE_COMPARISON SUBCOLLECTION
      // ===========================
      match /reference_comparison/{month} {
        // ✅ OPEN: Users can fully manage their reference bills
        allow read, write: if isOwner(userId);
      }
    }
  }
}